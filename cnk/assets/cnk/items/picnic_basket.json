{
  "model": {
    "type": "minecraft:select",
    "cases": [
      {
        "when": [
          "head"
        ],
        "model": {
          "type": "minecraft:condition",
          "property": "minecraft:custom_model_data",
          "on_false": {
            "type": "minecraft:model",
            "model": "cnk:block/picnic_basket_closed"
          },
          "on_true": {
            "type": "minecraft:model",
            "model": "cnk:block/picnic_basket_open"
          }
        }
      }
    ],
    "fallback": {
      "type": "minecraft:model",
      "model": "cnk:item/picnic_basket"
    },
    "property": "minecraft:display_context"
  }
}